---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script>
      import AOS from 'aos';
      import 'aos/dist/aos.css';
      AOS.init({
        duration: 800,
        easing: 'ease-in-out',
        once: true,
        offset: 80,
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Sampled from the floral painting */
    --color-darkest: #1A1412;  /* deep shadow of painting bg */
    --color-dark:    #7D3030;  /* wine/deep rose */
    --color-mid:     #C4887A;  /* dusty muted rose */
    --color-light:   #E8CCBC;  /* pale petal */
    --color-cream:   #F4EAE0;  /* warm off-white */

    --font-serif:   'Playfair Display', Georgia, serif;
    --font-sans:    'Lato', sans-serif;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--color-cream);
    color: var(--color-dark);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  section {
    padding: 5rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  h1, h2, h3 {
    font-family: var(--font-serif);
  }
</style>
