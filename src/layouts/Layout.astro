---
import FloatingNav from '../components/FloatingNav.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥂</text></svg>" />
  </head>
  <body>
    <slot />
    <FloatingNav />
    <script>
      import AOS from 'aos';
      import 'aos/dist/aos.css';
      AOS.init({
        duration: 800,
        easing: 'ease-in-out',
        once: true,
        offset: 80,
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Sampled from the floral painting */
    --color-darkest: #1A1412;  /* deep shadow of painting bg */
    --color-dark:    #7D3030;  /* wine/deep rose */
    --color-mid:     #C4887A;  /* dusty muted rose */
    --color-light:   #E8CCBC;  /* pale petal */
    --color-cream:   #F4EAE0;  /* warm off-white */

    --font-serif:   'Playfair Display', Georgia, serif;
    --font-sans:    'Lato', sans-serif;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  /* AOS leaves translateZ(0) on .aos-animate elements which creates a stacking
     context that clips filter:drop-shadow on children in Safari/WebKit.
     Resetting to none removes the stacking context without breaking the animation
     (browsers still interpolate from the initial translate to none correctly). */
  [data-aos^=fade].aos-animate {
    transform: none !important;
  }

  body {
    background-color: var(--color-cream);
    color: var(--color-dark);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }

  section {
    padding: 5rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  h1, h2, h3 {
    font-family: var(--font-serif);
  }
</style>
