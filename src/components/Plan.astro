---
const days = [
  {
    id: 'piatek',
    day: 'PIĄTEK',
    date: '18 Września',
    img: 'https://placehold.co/800x600/1A1412/E8CCBC?text=Piątek',
    thumb: 'https://placehold.co/400x300/1A1412/E8CCBC?text=Piątek',
    description: 'Przylot do Splitu i pierwsze chwile w mieście. Zameldowanie w apartamencie, wspólna kolacja w starym mieście przy kieliszku wina. Wieczorny spacer wzdłuż promenady Riva.',
  },
  {
    id: 'sobota',
    day: 'SOBOTA',
    date: '19 Września',
    img: 'https://placehold.co/800x600/7D3030/E8CCBC?text=Sobota',
    thumb: 'https://placehold.co/400x300/7D3030/E8CCBC?text=Sobota',
    description: 'Pełen dzień atrakcji — rejs po wyspach, pływanie w krystalicznej wodzie Adriatyku i lunch na pokładzie. Wieczorem wyjście do klubu i zabawa do białego rana.',
  },
  {
    id: 'niedziela',
    day: 'NIEDZIELA',
    date: '20 Września',
    img: 'https://placehold.co/800x600/C4887A/1A1412?text=Niedziela',
    thumb: 'https://placehold.co/400x300/C4887A/1A1412?text=Niedziela',
    description: 'Śniadanie na tarasie z widokiem na morze. Zwiedzanie Pałacu Dioklecjana i wąskich uliczek starego miasta. Relaks przy basenie, degustacja lokalnych win i oliwy.',
  },
  {
    id: 'poniedzialek',
    day: 'PONIEDZIAŁEK',
    date: '21 Września',
    img: 'https://placehold.co/800x600/E8CCBC/1A1412?text=Poniedziałek',
    thumb: 'https://placehold.co/400x300/E8CCBC/1A1412?text=Poniedziałek',
    description: 'Ostatni poranek w Splicie — zakupy z pamiątkami, wspólne śniadanie i wspomnienia na zawsze. Transfer na lotnisko i powrót do Warszawy z pełnymi sercami.',
  },
];
---

<section class="plan-section" id="plan">
  <div class="section-header" data-aos="fade-up">
    <p class="eyebrow">Co nas czeka?</p>
    <h2 class="title">Plan wyjazdu</h2>
    <div class="title-rule"></div>
  </div>

  <div class="cards-grid">
    {days.map((day, i) => (
      <button
        class="day-card"
        data-day-id={day.id}
        data-aos="fade-up"
        data-aos-delay={i * 80}
        aria-label={`Otwórz plan: ${day.day}`}
      >
        <div class="card-thumb">
          <img src={day.thumb} alt={day.day} />
          <div class="card-overlay">
            <span class="expand-icon">+</span>
          </div>
        </div>
        <div class="card-footer">
          <p class="card-day">{day.day}</p>
          <p class="card-date">{day.date}</p>
        </div>
      </button>
    ))}
  </div>
</section>

<!-- Modal -->
<div class="modal-backdrop" id="plan-modal" aria-hidden="true">
  <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="modal-day-name">
    <button class="modal-close" id="modal-close" aria-label="Zamknij">✕</button>
    <div class="modal-image-wrap">
      <img id="modal-img" src="" alt="" />
    </div>
    <div class="modal-text">
      <p class="modal-date" id="modal-date"></p>
      <h3 class="modal-day" id="modal-day-name"></h3>
      <p class="modal-desc" id="modal-desc"></p>
    </div>
  </div>
</div>

<script define:vars={{ days }}>
  const backdrop = document.getElementById('plan-modal');
  const modalImg  = document.getElementById('modal-img');
  const modalDate = document.getElementById('modal-date');
  const modalDay  = document.getElementById('modal-day-name');
  const modalDesc = document.getElementById('modal-desc');
  const closeBtn  = document.getElementById('modal-close');

  const dataMap = Object.fromEntries(days.map(d => [d.id, d]));

  function openModal(id) {
    const d = dataMap[id];
    if (!d) return;
    modalImg.src  = d.img;
    modalImg.alt  = d.day;
    modalDate.textContent = d.date;
    modalDay.textContent  = d.day;
    modalDesc.textContent = d.description;
    backdrop.classList.add('open');
    backdrop.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    centerModalBox();
  }

  function centerModalBox() {
    if (window.innerWidth > 600) return;
    var box = backdrop.querySelector('.modal-box');
    if (!box) return;
    // align-items:center centers against 100vh, which on mobile can be taller
    // than the real visible area (browser chrome eats into it). Measure the
    // actual box height and the true visible height, then position explicitly.
    var vh = window.visualViewport ? window.visualViewport.height : window.innerHeight;
    var boxH = box.offsetHeight;
    var top = Math.max(16, Math.round((vh - boxH) / 2));
    box.style.marginTop = top + 'px';
  }

  function closeModal() {
    backdrop.classList.remove('open');
    backdrop.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    var box = backdrop.querySelector('.modal-box');
    if (box) box.style.marginTop = '';
  }

  if (window.visualViewport) {
    window.visualViewport.addEventListener('resize', () => {
      if (backdrop.classList.contains('open')) centerModalBox();
    });
  }

  document.querySelectorAll('.day-card').forEach(btn => {
    btn.addEventListener('click', () => openModal(btn.dataset.dayId));
  });

  closeBtn.addEventListener('click', closeModal);

  backdrop.addEventListener('click', e => {
    if (e.target === backdrop) closeModal();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModal();
  });
</script>

<style>
  .plan-section {
    background-color: var(--color-light);
    max-width: 100%;
    padding: 5rem 2rem;
  }

  /* ── Header ── */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
    opacity: 0.7;
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--color-darkest);
    font-style: italic;
    font-weight: 400;
  }

  .title-rule {
    width: 50px;
    height: 1px;
    background: var(--color-dark);
    margin: 0.8rem auto 0;
    opacity: 0.5;
  }

  /* ── Cards ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .cards-grid { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  }

  .day-card {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* ── Thumb ── */
  .card-thumb {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: sepia(10%);
    transition: transform 0.5s ease, filter 0.4s ease;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 20, 18, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.35s ease;
  }

  .expand-icon {
    color: var(--color-cream);
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1;
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 0.3s ease, transform 0.3s ease;
    font-family: var(--font-serif);
  }

  .day-card:hover .card-thumb img {
    transform: scale(1.06);
    filter: sepia(20%);
  }

  .day-card:hover .card-overlay {
    background: rgba(26, 20, 18, 0.45);
  }

  .day-card:hover .expand-icon {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Card footer ── */
  .card-footer {
    padding: 0.75rem 0 0;
    border-top: 1px solid var(--color-mid);
    margin-top: 0.1rem;
  }

  .card-day {
    font-family: var(--font-serif);
    font-size: clamp(0.85rem, 1.5vw, 1.05rem);
    font-style: italic;
    color: var(--color-darkest);
    letter-spacing: 0.05em;
  }

  .card-date {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-dark);
    opacity: 0.7;
    margin-top: 0.15rem;
    font-family: var(--font-sans);
  }

  /* ── Modal ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(26, 20, 18, 0.85);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .modal-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }

  .modal-box {
    background: var(--color-cream);
    max-width: 820px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    transform: translateY(20px);
    transition: transform 0.35s ease;
  }

  .modal-backdrop.open .modal-box {
    transform: translateY(0);
  }

  .modal-close {
    position: absolute;
    top: 0.8rem;
    right: 0.9rem;
    background: none;
    border: none;
    font-size: 1.2rem;
    color: var(--color-dark);
    cursor: pointer;
    z-index: 1;
    line-height: 1;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .modal-close:hover { opacity: 1; }

  .modal-image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    flex-shrink: 0;
  }

  .modal-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .modal-text {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
  }

  /* ── Mobile: flex column so the text pane can scroll, never clips content ── */
  @media (max-width: 600px) {
    .modal-backdrop {
      padding: 0 1rem;
      align-items: flex-start;
      overflow-y: auto;
    }

    .modal-box {
      display: flex;
      flex-direction: column;
      max-height: 85vh;
      width: 100%;
      max-width: 100%;
      overflow: hidden;
      transform: none;
      transition: none;
    }

    .modal-image-wrap {
      aspect-ratio: unset;
      height: 200px;
      flex-shrink: 0;
    }

    .modal-text {
      flex: 1;
      min-height: 0;      /* lets flex child shrink so overflow-y: auto kicks in */
      overflow-y: auto;
      padding: 1.25rem 1.25rem 2.5rem;
      justify-content: flex-start;
    }

    .modal-close {
      top: 0.6rem;
      right: 0.75rem;
      font-size: 1.5rem;
      opacity: 0.85;
    }
  }

  .modal-date {
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-mid);
    font-family: var(--font-sans);
  }

  .modal-day {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-darkest);
    line-height: 1.1;
  }

  .modal-desc {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    line-height: 1.75;
    color: var(--color-dark);
    margin-top: 0.5rem;
    font-weight: 300;
  }
</style>
