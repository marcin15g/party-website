---
import OrnateFrame from './OrnateFrame.astro';

const bride = {
  name: 'Panna Młoda',
  img: '/images/bride.jpg',
};

const participants = [
  { name: 'Ola', img: '/images/participant-1.jpg' },
  { name: 'Wiktoria', img: '/images/participant-2.jpg' },
  { name: 'Basia', img: '/images/participant-3.jpg' },
  { name: 'Tosia', img: '/images/participant-4.jpg' },
  { name: 'Agnieszka', img: '/images/participant-5.jpg' },
];
---

<section class="participants-section" id="participants">
  <!-- Bride -->
  <div class="bride-wrapper" data-aos="fade-up">
    <p class="section-label">PANNA MŁODA</p>
    <div class="bride-frame">
      <OrnateFrame>
        <img src={bride.img} alt={bride.name} />
      </OrnateFrame>
    </div>
  </div>

  <!-- Divider -->
  <div class="divider" data-aos="fade-up">
    <span>POZOSTAŁE UCZESTNICZKI</span>
  </div>

  <!-- Participants grid -->
  <div class="participants-grid">
    {participants.map((p, i) => (
      <div class="participant" data-aos="fade-up" data-aos-delay={i * 80}>
        <div class="participant-frame">
          <OrnateFrame>
            <img src={p.img} alt={p.name} />
          </OrnateFrame>
        </div>
        <p class="participant-name">{p.name}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .participants-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    background-color: var(--color-cream);
    max-width: 100%;
    padding: 5rem 1.5rem;
  }

  /* ── Section label ── */
  .section-label {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 4vw, 2rem);
    letter-spacing: 0.3em;
    color: var(--color-mid);
    text-align: center;
    margin-bottom: 1.2rem;
    font-style: italic;
    font-weight: bold;
  }

  /* ── Bride frame ── */
  .bride-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bride-frame {
    width: min(320px, 80vw);
  }

  /* ── Divider ── */
  .divider {
    width: 100%;
    max-width: 700px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-mid);
    opacity: 0.6;
  }

  .divider span {
    font-family: var(--font-serif);
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    letter-spacing: 0.25em;
    color: var(--color-dark);
    white-space: nowrap;
    font-style: italic;
  }

  /* ── Participants grid ── */
  .participants-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    width: 100%;
    max-width: 1000px;
  }

  .participant {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .participant-frame {
    width: min(190px, 44vw);
  }

  .participant-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-dark);
    font-style: italic;
    letter-spacing: 0.05em;
  }

  /* ── Mobile: force 2 columns ── */
  @media (max-width: 600px) {
    .participants-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      justify-items: stretch;
      gap: 1.5rem 1rem;
    }

    .participant-frame {
      width: 100%;
    }

    /* Lone last participant (odd total) spans both columns, centered at the same size as the rest */
    .participant:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      width: calc(50% - 0.5rem);
      justify-self: center;
    }
  }
</style>
